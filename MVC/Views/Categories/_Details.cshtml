@model CategoryModel

<dl class="row">
    <dt class="col-2">
        @Html.DisplayNameFor(model => model.Name)
    </dt>
    <dd class="col-10">
        @Html.DisplayFor(model => model.Name)
    </dd>
    @if (Model.ProductCountOutput > 0)
    {
        <dt class="col-2">
            @Html.DisplayNameFor(model => model.ProductsOutput)
        </dt>
        <dd class="col-10">
            @Html.Raw(Model.ProductsOutput)
        </dd>
    }
</dl>